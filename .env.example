NEXT_PUBLIC_SUPPORT_PHONE="(555) 000-0000"
NEXT_PUBLIC_SUPPORT_PHONE_HREF="tel:+15550000000"
NEXT_PUBLIC_SUPPORT_EMAIL="info@firstdueadvisors.com"
NEXT_PUBLIC_BUSINESS_ADDRESS="City, State"

# ─── CTAs & Messaging ────────────────────────────────────────────────────────
NEXT_PUBLIC_CTA_PRIMARY="Get a Free Consultation"
NEXT_PUBLIC_CTA_SECONDARY="Speak with an Advisor"
NEXT_PUBLIC_CTA_PHONE="Call Now"
NEXT_PUBLIC_FORM_SUCCESS_MESSAGE="Thank you. Brandon will be in touch within one business day."

# ─── Author / Licensing ──────────────────────────────────────────────────────
NEXT_PUBLIC_AUTHOR_NAME="Brandon Grimes"
NEXT_PUBLIC_AUTHOR_TITLE="Licensed Insurance Professional"
NEXT_PUBLIC_AUTHOR_CREDENTIAL="22 Years Experience | Health, Life & Estate Planning"
NEXT_PUBLIC_AUTHOR_BIO="Brandon Grimes founded First Due Advisors to bring a higher standard of care and ethics to the insurance industry. With over 22 years of experience and a background as a first responder, Brandon built a brokerage where every agent shares that same commitment to community and integrity."
NEXT_PUBLIC_LICENSED_ENTITY_NAME="First Due Advisors"
NEXT_PUBLIC_LICENSED_STATES="State, State, State"

# ─── Supabase ────────────────────────────────────────────────────────────────
# Found in: Supabase dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Resend ──────────────────────────────────────────────────────────────────
# Found in: resend.com > API Keys
RESEND_API_KEY=
RESEND_FROM_EMAIL="noreply@firstdueadvisors.com"
RESEND_FROM_NAME="First Due Advisors"
RESEND_LEAD_NOTIFY_EMAIL=leads@firstdueadvisors.com

# ─── Analytics ───────────────────────────────────────────────────────────────
# Found in: Google Analytics 4 > Admin > Data Streams
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ─── Upstash Redis ───────────────────────────────────────────────────────────
# Found in: console.upstash.com > your Redis database > REST API
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
