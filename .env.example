# ─── Site Identity ───────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://firstdueadvisors.com
NEXT_PUBLIC_SITE_NAME="First Due Advisors"
NEXT_PUBLIC_SITE_TAGLINE="Service, Trust, and Integrity First"
NEXT_PUBLIC_SITE_DESCRIPTION="First Due Advisors is a firefighter-owned insurance brokerage specializing in Medicare, health, life, annuities, and estate planning. Founded by first responders. Built on ethics."

# ─── Contact Info ─────────────────────────────────────────────────────────────
